VITE_SUI_NETWORK=testnet
VITE_SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443
VITE_SUI_FRAMEWORK_PACKAGE_ID=0x2
VITE_SUI_RANDOM_PACKAGE_ID=0x8
VITE_LOTTERY_PACKAGE_ID=0x54e4ab9a7dfb6fbcf5cd0e99a697f321ee09515634b1b23a6cbfb7a477960b0c
VITE_LOTTERY_OBJECT_ID=0x<FIND_VIA_EXPLORER_BELOW>
VITE_TWD_BANK_OBJECT_ID=0x<FIND_TWD_BANK_OBJECT_ID>

# onchain_invoice (required for issuing 1 TWD/USDC test token in Admin panel)
VITE_INVOICE_PACKAGE_ID=0x<INVOICE_PACKAGE_ID>
VITE_INVOICE_SYSTEM_ID=0x<INVOICE_SYSTEM_ID>
VITE_INVOICE_TREASURY_ID=0x<INVOICE_TREASURY_ID>
VITE_INVOICE_USDC_TREASURY_CAP_ID=0x<INVOICE_USDC_TREASURY_CAP_ID>
VITE_INVOICE_TAX_TREASURY_CAP_ID=0x<INVOICE_TAX_TREASURY_CAP_ID>
VITE_INVOICE_ADMIN_ID=0x<INVOICE_ADMIN_ID>

# HOW TO FIND VITE_LOTTERY_OBJECT_ID:
# 1. Visit Sui Testnet Explorer: https://suiscan.xyz/testnet
# 2. Search for the Package ID above (0x54e4ab9a...)
# 3. Go to "Created Objects" tab
# 4. Find the object with type "0x54e4ab9a...::scratch::ScratchLottery"
# 5. Copy its Object ID and replace 0x<FIND_VIA_EXPLORER_BELOW> above
